# Copy this file to .env and edit the values before first run.

# --- Database ---
POSTGRES_USER=hem
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=hem

# --- App ---
# Port exposed on the NAS / host. Open the UI at http://<nas-ip>:8095
# 8095 (not 8080) because many NAS web UIs / reverse proxies already hold 8080.
APP_PORT=8095

# Secret used to sign login sessions. Use a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# The first admin user is created automatically on first run.
# After first login you can change the password from the UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Default currency (can be changed later in Settings). e.g. USD, EUR, AZN, GBP
DEFAULT_CURRENCY=AZN
